# LLM Provider: openai (default) or ollama (local, free)
LLM_PROVIDER=openai

# OpenAI — direct API
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI — set endpoint to use Azure instead of direct OpenAI
# OPENAI_AZURE_API_ENDPOINT=https://your-resource.openai.azure.com
# OPENAI_AZURE_API_VERSION=2024-12-01-preview

# Ollama (local — no API key needed)
# Install: brew install ollama (macOS) or curl -fsSL https://ollama.com/install.sh | sh (Linux)
# Then:    ollama pull llama3.1:8b && ollama serve
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Whisper model: tiny, base (default), small, medium
WHISPER_MODEL=base

# Max upload file size in MB
MAX_FILE_SIZE_MB=50
